untitled2.app/Contents/PkgInfo: 
	@test -d untitled2.app/Contents || mkdir -p untitled2.app/Contents
	@$(DEL_FILE) untitled2.app/Contents/PkgInfo
	@echo "APPL????" > untitled2.app/Contents/PkgInfo
untitled2.app/Contents/Info.plist: 
	@test -d untitled2.app/Contents || mkdir -p untitled2.app/Contents
	@$(DEL_FILE) untitled2.app/Contents/Info.plist
	@set -o pipefail && plutil -convert xml1 -o - ../../../../Qt/6.11.0/macos/mkspecs/macx-clang/Info.plist.app | sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,1.untitled2,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},1.untitled2,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},13,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,\$${IOS_LAUNCH_SCREEN},LaunchScreen,g" -e "s,@ICON@,,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},,g" -e "s,@EXECUTABLE@,untitled2,g" -e "s,@LIBRARY@,untitled2,g" -e "s,\$${EXECUTABLE_NAME},untitled2,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" >untitled2.app/Contents/Info.plist

all: Makefile \
		untitled2.app/Contents/PkgInfo \
		untitled2.app/Contents/Info.plist untitled2.app/Contents/MacOS/untitled2

dist: distdir FORCE
	(cd `dirname $(DISTDIR)` && $(TAR) $(DISTNAME).tar $(DISTNAME) && $(COMPRESS) $(DISTNAME).tar) && $(MOVE) `dirname $(DISTDIR)`/$(DISTNAME).tar.gz . && $(DEL_FILE) -r $(DISTDIR)

distdir: FORCE
	@test -d $(DISTDIR) || mkdir -p $(DISTDIR)
	$(COPY_FILE) --parents $(DIST) $(DISTDIR)/
	$(COPY_FILE) --parents ../../adminwidget.h ../../bankrecord.h ../../basewidget.h ../../constants.h ../../creditcalc.h ../../creditformwidget.h ../../credittablewidget.h ../../datahandler.h ../../depositcalc.h ../../depositformwidget.h ../../depositwidget.h ../../loginwidget.h ../../mainwindow.h ../../successwidget.h ../../userwidget.h $(DISTDIR)/
	$(COPY_FILE) --parents ../../adminwidget.cpp ../../bankrecord.cpp ../../creditcalc.cpp ../../creditformwidget.cpp ../../credittablewidget.cpp ../../datahandler.cpp ../../depositcalc.cpp ../../depositformwidget.cpp ../../depositwidget.cpp ../../loginwidget.cpp ../../main.cpp ../../mainwindow.cpp ../../successwidget.cpp ../../userwidget.cpp $(DISTDIR)/
	$(COPY_FILE) --parents ../../UserForm.ui ../../mainwindow.ui $(DISTDIR)/


